export IMAGE_NAME=ib-gateway-docker
export TRADING_MODE=paper
if [ -f ".secrets" ] ; then
    # `set -a` auto-exports any var assigned during the source so docker
    # compose (a subprocess) actually sees them. Bare `KEY=VALUE` lines in
    # .secrets do not export by themselves.
    set -a
    source ./.secrets
    set +a
fi

if [ -d ".venv" ] ; then
    source ./.venv/bin/activate
    unset PS1
fi
