# Local-only secrets. Copy to `.env` and fill in your real values.
# `.env` is git-ignored; do NOT commit it.
#
# Pinned IB Gateway / IBC versions live in `versions.env` (committed).

# Required by start.sh / docker-compose for a single-gateway run:
IB_ACCOUNT=your_ib_username
IB_PASSWORD=your_ib_password
TRADING_MODE=paper

# Optional: separate paper + live credentials for running two containers
# at once (e.g. via docker-compose with distinct services). The bundled
# image only reads IB_ACCOUNT/IB_PASSWORD; the *_PAPER / *_LIVE pairs are
# convenience vars for compose files or shell scripts that select between
# them.
IB_PAPER_ACCOUNT=your_paper_username
IB_PAPER_PASSWORD=your_paper_password
IB_LIVE_ACCOUNT=your_live_username
IB_LIVE_PASSWORD=your_live_password

# ── Session persistence (optional; defaults are baked into the image) ──
# IB Gateway's own scheduled "soft restart" — preserves session, no 2FA.
# Time is in UTC (the container's user.timezone). Default is sized to fall
# in the gap between HK regular close (08:00 UTC) and US regular open
# (13:30 UTC summer / 14:30 UTC winter).
# IBC_AUTO_RESTART_TIME=11:00 AM
#
# IBC command server — receives "RESTART" / "STOP" over TCP. Default 7462.
# Multi-container deployments must use distinct ports per service.
# IBC_COMMAND_SERVER_PORT=7462
#
# Address the command server binds to. Default 127.0.0.1 (loopback only).
# DO NOT change to a non-loopback value unless you control who can reach
# the port — anyone connecting can shut down or restart the gateway.
# IBC_BIND_ADDRESS=127.0.0.1
